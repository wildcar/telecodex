[Unit]
Description=Telecodex Telegram Bot
After=network.target

[Service]
Type=simple
User=keeper
Group=keeper
WorkingDirectory=/opt/telecodex
EnvironmentFile=/opt/telecodex/.env
ExecStart=/opt/telecodex/.venv/bin/python -m telecodex.main
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false

[Install]
WantedBy=multi-user.target
